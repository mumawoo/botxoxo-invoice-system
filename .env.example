# Telegram polling bot. Leave blank until BotFather gives you a token.
TELEGRAM_BOT_TOKEN=

# Numeric Telegram user IDs allowed to send photos. Commas, semicolons, spaces,
# and labels such as "Marco: 123456789" are accepted.
TELEGRAM_ALLOWED_USER_IDS=

# Set true only if photos sent to Telegram should be processed immediately.
TELEGRAM_AUTO_PROCESS=false

# Telegram reply language: en or zh. Users can also switch with /lang zh or /lang en.
TELEGRAM_LANGUAGE=en

# Company-specific category rules. All Telegram users share this profile for now.
COMPANY_PROFILE=default

# Pairing mode:
# auto   = daily workflow; merge likely invoice/payment-slip pairs and calculate tips.
# review = monthly unordered workflow; keep rows, group possible pairs in Remarks for human review.
PAIRING_MODE=auto

# Qwen Scan. Production OCR sends each crop to Qwen. DASHSCOPE_API_KEY
# is also accepted as an alias for QWEN_API_KEY.
QWEN_API_KEY=
QWEN_MODEL=qwen-vl-max
QWEN_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1/chat/completions
ENABLE_QWEN_SCAN=false

# OpenAI/Codex fallback has been removed from production scanning.
ENABLE_AI_VISUAL_COUNT=false
AI_VISUAL_COUNT_MIN_OPENCV_CROPS=4

# Local OCR settings.
PADDLEOCR_LANG=en
EASYOCR_LANGS=es,en
TESSERACT_CMD=tesseract
TESSERACT_LANG=eng+spa
TESSERACT_PSM=6
LOCAL_OCR_CONFIDENCE_THRESHOLD=0.62
AMOUNT_TOLERANCE_MXN=0.50
